{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run TwoSum Tests",
            "type": "shell",
            "command": "/Applications/MATLAB_R2025a.app/bin/matlab",
            "args": [
                "-nodesktop",
                "-nosplash",
                "-batch",
                "run('Grind75/Test_TwoSum.m')"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "Run Current .m File",
            "type": "shell",
            "command": "/Applications/MATLAB_R2025a.app/bin/matlab",
            "args": [
                "-nodesktop",
                "-nosplash",
                "-batch",
                "run('${relativeFile}')"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "MATLAB REPL in Terminal",
            "type": "shell",
            "command": "/Applications/MATLAB_R2025a.app/bin/matlab",
            "args": [
                "-nodesktop",
                "-nosplash"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Run LeetCode Tests (Reference)",
            "type": "shell",
            "command": "/Applications/MATLAB_R2025a.app/bin/matlab",
            "args": [
                "-nodesktop",
                "-nosplash",
                "-batch",
                "cd('leetcode/tests'); test_all"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "Run LeetCode Tests (User)",
            "type": "shell",
            "command": "/Applications/MATLAB_R2025a.app/bin/matlab",
            "args": [
                "-nodesktop",
                "-nosplash",
                "-batch",
                "cd('leetcode/tests'); test_all('user')"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        },
        {
            "label": "Generate ctags",
            "type": "shell",
            "command": "ctags",
            "args": [
                "--options=../.ctags",
                "."
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared",
                "clear": false
            }
        }
    ]
}
